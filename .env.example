# ═══════════════════════════════════════════════════════════
# PawRoute V2.0 — Environment Variables
# Copy this file to .env and fill in all required values.
# NEVER commit your .env file to git.
# ═══════════════════════════════════════════════════════════

# ─── App ─────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
LOG_LEVEL=info

# ─── Database (Supabase) ─────────────────────────────────
# Get from: https://supabase.com → Project Settings → Database
DATABASE_URL=postgresql://postgres:[YOUR-PASSWORD]@db.[YOUR-REF].supabase.co:5432/postgres
# For local dev with docker-compose:
# DATABASE_URL=postgresql://pawroute:pawroute_dev@localhost:5432/pawroute

SUPABASE_URL=https://[YOUR-REF].supabase.co
SUPABASE_ANON_KEY=                      # Project Settings → API → anon key
SUPABASE_SERVICE_ROLE_KEY=              # Project Settings → API → service_role key (keep secret!)
SUPABASE_STORAGE_BUCKET=pawroute-media

# ─── Redis (Upstash) ─────────────────────────────────────
# Get from: https://console.upstash.com → Create Database → REST API
# For local dev with docker-compose, use ioredis instead (see lib/redis.ts)
UPSTASH_REDIS_REST_URL=https://[YOUR-DB].upstash.io
UPSTASH_REDIS_REST_TOKEN=               # Upstash dashboard → REST Token

# ─── JWT Secrets ────────────────────────────────────────
# Generate with: node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_ACCESS_SECRET=                      # min 32 chars
JWT_REFRESH_SECRET=                     # min 32 chars (different from access)
JWT_ADMIN_SECRET=                       # min 32 chars (different from both above)

# ─── Google (OAuth 2.0 + Gemini AI) ─────────────────────
# OAuth: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
# Gemini: https://aistudio.google.com → Get API Key (FREE tier available)
GEMINI_API_KEY=

# ─── Facebook OAuth ──────────────────────────────────────
# https://developers.facebook.com → My Apps → Create App
FACEBOOK_APP_ID=
FACEBOOK_APP_SECRET=

# ─── Stripe Payments ─────────────────────────────────────
# https://dashboard.stripe.com → Developers → API keys
STRIPE_SECRET_KEY=sk_test_...           # test key for dev; sk_live_... for prod
STRIPE_WEBHOOK_SECRET=whsec_...        # Stripe CLI: stripe listen --forward-to localhost:3000/api/v1/payments/webhook
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_...

# ─── Firebase Cloud Messaging ────────────────────────────
# https://console.firebase.google.com → Project Settings → Service Accounts → Generate key
FIREBASE_PROJECT_ID=
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@your-project.iam.gserviceaccount.com

# ─── Email (Resend) ───────────────────────────────────────
# https://resend.com → API Keys (FREE: 3,000 emails/month)
RESEND_API_KEY=re_...
EMAIL_FROM=noreply@pawroute.com

# ─── WhatsApp Cloud API (Meta) ───────────────────────────
# https://developers.facebook.com → WhatsApp → Getting Started
# Requires Meta Business verification
WHATSAPP_PHONE_NUMBER_ID=
WHATSAPP_ACCESS_TOKEN=

# ─── Hugging Face (AI Breed Detection) ───────────────────
# https://huggingface.co → Settings → Access Tokens (FREE tier available)
HUGGINGFACE_API_KEY=hf_...

# ─── App URLs ────────────────────────────────────────────
NEXT_PUBLIC_API_URL=http://localhost:3000
NEXT_PUBLIC_WEB_URL=http://localhost:3001
NEXT_PUBLIC_ADMIN_URL=http://localhost:3002
# Production:
# NEXT_PUBLIC_API_URL=https://api.pawroute.com
# NEXT_PUBLIC_WEB_URL=https://pawroute.com
# NEXT_PUBLIC_ADMIN_URL=https://admin.pawroute.com

# ─── Sentry Error Tracking ───────────────────────────────
# https://sentry.io → Create Project (FREE: 5K errors/month)
# Create 3 projects: pawroute-api, pawroute-web, pawroute-admin
SENTRY_DSN=                                     # API server DSN
NEXT_PUBLIC_SENTRY_DSN=                         # Web app DSN (public)
VITE_SENTRY_DSN=                                # Admin panel DSN (public)
SENTRY_ORG=your-org-slug                        # Sentry org for source map upload
SENTRY_PROJECT=pawroute-web                     # Sentry project name
SENTRY_AUTH_TOKEN=                              # Sentry → Settings → Auth Tokens

# ─── Optional: Admin Panel IP Allowlist ──────────────────
# Comma-separated IPs allowed to access admin panel in production
# Leave empty to allow all IPs
ADMIN_IP_ALLOWLIST=
