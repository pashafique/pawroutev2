{
  "name": "@pawroute/api",
  "version": "2.0.0",
  "private": true,
  "type": "module",
  "main": "./src/server.ts",
  "scripts": {
    "dev": "node --env-file=.env --import tsx/esm --watch src/server.ts",
    "build": "prisma generate && tsc --project tsconfig.build.json",
    "start": "node --env-file=.env dist/server.js",
    "lint": "eslint src --ext .ts",
    "type-check": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "prisma migrate dev",
    "db:migrate:deploy": "prisma migrate deploy",
    "db:seed": "node --env-file=.env --import tsx/esm prisma/seed.ts",
    "db:studio": "prisma studio",
    "db:generate": "prisma generate"
  },
  "dependencies": {
    "@aws-sdk/client-s3": "^3.600.0",
    "@fastify/cors": "^9.0.1",
    "@fastify/helmet": "^11.1.1",
    "@fastify/jwt": "^8.0.1",
    "@fastify/multipart": "^8.3.0",
    "@fastify/rate-limit": "^9.1.0",
    "@fastify/swagger": "^8.14.0",
    "@fastify/swagger-ui": "^4.0.1",
    "@google/generative-ai": "^0.15.0",
    "@pawroute/config": "workspace:*",
    "@pawroute/types": "workspace:*",
    "@pawroute/utils": "workspace:*",
    "@prisma/client": "^5.16.0",
    "@sentry/node": "^8.0.0",
    "@supabase/supabase-js": "^2.44.0",
    "@upstash/redis": "^1.31.0",
    "bcryptjs": "^2.4.3",
    "bullmq": "^5.10.0",
    "date-fns": "^3.6.0",
    "fastify": "^4.28.0",
    "firebase-admin": "^12.2.0",
    "ioredis": "^5.4.1",
    "jsonwebtoken": "^9.0.2",
    "pdfkit": "^0.15.0",
    "pino": "^9.3.2",
    "pino-pretty": "^11.2.1",
    "resend": "^3.3.0",
    "sharp": "^0.33.4",
    "stripe": "^16.2.0",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/jsonwebtoken": "^9.0.6",
    "@types/node": "^20.14.0",
    "@types/pdfkit": "^0.13.5",
    "prisma": "^5.16.0",
    "tsx": "^4.16.2",
    "typescript": "^5.5.0",
    "vitest": "^1.6.0"
  }
}
